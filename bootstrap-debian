#!/usr/bin/env bash
# Provision a fresh Debian/Ubuntu box as root, then link dotfiles. See README.
set -euo pipefail

# Derive the GitHub owner + clone URL from this repo's own origin — no hardcoding.
SELF=$(cd "$(dirname "$0")" && pwd)
SLUG=$(git -C "$SELF" remote get-url origin 2>/dev/null | sed -E 's#^(https://github\.com/|git@github\.com:)##; s#\.git$##') || true
[[ -n "$SLUG" ]] || {
  echo "can't read git remote — run from a clone of your dotfiles repo" >&2
  exit 1
}
GH=${SLUG%%/*}
REPO="https://github.com/$SLUG"

DRY=0
ARGS=()
for a in "$@"; do
  case "$a" in
  --dry-run) DRY=1 ;;
  *) ARGS+=("$a") ;;
  esac
done
USER_NAME="${ARGS[0]:-}"
[[ -n "$USER_NAME" ]] || {
  echo "usage: bootstrap-debian [--dry-run] <username>" >&2
  exit 2
}
[[ "$(id -u)" == 0 ]] || {
  echo "run as root on a fresh box" >&2
  exit 1
}
HOME_DIR="/home/$USER_NAME"

say() { printf '\n\033[1;34m:: %s\033[0m\n' "$*"; }
run() { if ((DRY)); then
  printf '[dry-run]'
  printf ' %q' "$@"
  echo
else "$@"; fi; }
write() { if ((DRY)); then
  echo "[dry-run] write $1"
  cat >/dev/null
else cat >"$1"; fi; }

say "Installing apt baseline (system + Homebrew deps)"
run apt-get update -y
run env DEBIAN_FRONTEND=noninteractive apt-get install -y \
  git sudo build-essential procps curl file ca-certificates unzip \
  ufw fail2ban unattended-upgrades sysfsutils

say "Creating user $USER_NAME with passwordless sudo"
id "$USER_NAME" &>/dev/null || run adduser --disabled-password --gecos "" "$USER_NAME"
run usermod -aG sudo "$USER_NAME"
printf '%s ALL=(ALL) NOPASSWD:ALL\n' "$USER_NAME" | write /etc/sudoers.d/90-bootstrap
run chmod 440 /etc/sudoers.d/90-bootstrap
run visudo -cf /etc/sudoers.d/90-bootstrap

say "Authorizing SSH key from github.com/$GH.keys"
keys=$(curl -fsSL "https://github.com/$GH.keys") || true
[[ -n "${keys:-}" ]] || {
  echo "!! no keys at github.com/$GH.keys — aborting before lockout" >&2
  exit 1
}
run install -d -m700 -o "$USER_NAME" -g "$USER_NAME" "$HOME_DIR/.ssh"
printf '%s\n' "$keys" | write "$HOME_DIR/.ssh/authorized_keys"
run chmod 600 "$HOME_DIR/.ssh/authorized_keys"
run chown "$USER_NAME:$USER_NAME" "$HOME_DIR/.ssh/authorized_keys"

say "Hardening: firewall, fail2ban, key-only SSH"
port=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}') || true
port=${port:-22}
run ufw allow "$port"/tcp
run ufw default deny incoming
run ufw default allow outgoing
run ufw --force enable
run systemctl enable --now fail2ban
printf 'PasswordAuthentication no\nPermitRootLogin no\n' | write /etc/ssh/sshd_config.d/00-harden.conf
printf 'APT::Periodic::Update-Package-Lists "1";\nAPT::Periodic::Unattended-Upgrade "1";\n' |
  write /etc/apt/apt.conf.d/20auto-upgrades
run systemctl reload ssh || true # socket-activated sshd may have no service to reload

say "Configuring 4G swap + zswap (zstd), vm.swappiness=10"
if ! swapon --show 2>/dev/null | grep -q .; then
  run fallocate -l 4G /swapfile
  run chmod 600 /swapfile
  run mkswap /swapfile
  run swapon /swapfile
  grep -qxF '/swapfile none swap sw 0 0' /etc/fstab 2>/dev/null ||
    run bash -c "printf '%s\n' '/swapfile none swap sw 0 0' >> /etc/fstab"
fi
# zswap compresses swap pages in RAM (zstd) and tiers cold ones to the file.
# sysfsutils replays /etc/sysfs.d/*.conf at boot; also enable it now.
printf 'module/zswap/parameters/compressor = zstd\nmodule/zswap/parameters/zpool = zsmalloc\nmodule/zswap/parameters/enabled = 1\n' |
  write /etc/sysfs.d/zswap.conf
run bash -c 'echo zstd > /sys/module/zswap/parameters/compressor; echo zsmalloc > /sys/module/zswap/parameters/zpool; echo 1 > /sys/module/zswap/parameters/enabled' || true
printf 'vm.swappiness=10\n' | write /etc/sysctl.d/99-swappiness.conf
run sysctl -p /etc/sysctl.d/99-swappiness.conf

say "Installing Homebrew + Brewfile + dotfiles (as $USER_NAME)"
run sudo -iu "$USER_NAME" bash -s "$REPO" <<'EOF'
set -euo pipefail
repo="$1"
# Clone, link configs, and wire the shell FIRST — these matter most for daily
# use and don't need Homebrew, so a later brew failure can't skip them.
git clone "$repo" ~/src/dotfiles 2>/dev/null || git -C ~/src/dotfiles pull --ff-only
~/src/dotfiles/install
# Login shell stays bash so scripts and AI agents get POSIX; interactive
# sessions hand off to fish. Non-interactive `bash -c` never trips this guard.
grep -qF 'interactive-fish' ~/.bashrc 2>/dev/null || printf '%s\n' \
  '' \
  '# interactive-fish: humans get fish; scripts and AI agents stay in bash.' \
  'if [[ $- == *i* && -z ${FISH_LAUNCHED:-} ]]; then' \
  '    for _f in /home/linuxbrew/.linuxbrew/bin/fish /usr/bin/fish; do' \
  '        [ -x "$_f" ] && { export FISH_LAUNCHED=1; exec "$_f"; }' \
  '    done' \
  'fi' >> ~/.bashrc
# Homebrew + toolbelt LAST (best-effort; a failed formula won't break the shell).
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ] \
  || NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
  brew bundle --file ~/src/dotfiles/Brewfile || echo "!! some Brewfile formulae failed; finish later with: brew bundle --file ~/src/dotfiles/Brewfile"
fi
EOF

host=$(awk '{print $3}' <<<"${SSH_CONNECTION:-}")
host=${host:-$(hostname -I 2>/dev/null | awk '{print $1}')}
host=${host:-<host>}
say "Done. In a NEW terminal: ssh $USER_NAME@$host — confirm it works before closing this session."
